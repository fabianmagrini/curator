# Gateway
PORT=4000
WEB_ORIGIN=http://localhost:5173

# Persistence: when set, the gateway uses Postgres; when unset, it uses in-memory
# stores (ADR-0012, ADR-0013). Local DB via `docker compose up -d`.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/curator

# CopilotKit runtime (UX chat layer, ADR-0015). Opt-in: when GOOGLE_API_KEY is set
# the gateway serves POST /copilotkit backed by Gemini; when unset it returns 503.
# GOOGLE_API_KEY=your-google-ai-studio-key
# GEMINI_MODEL=gemini-2.5-flash

# Web (Vite) — must be prefixed with VITE_ to be exposed to the browser
VITE_GATEWAY_URL=http://localhost:4000
# Set to enable the CopilotKit sidebar in the web app (points at the gateway runtime).
# VITE_COPILOT_RUNTIME_URL=http://localhost:4000/copilotkit
