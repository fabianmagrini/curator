{
  "name": "@curator/gateway",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AG-UI gateway (NestJS) — enterprise control plane for the Tech Radar Curator",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json && concurrently -k -n tsc,api \"tsc -p tsconfig.json -w --preserveWatchOutput\" \"node --watch dist/main.js\"",
    "start": "node dist/main.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "@copilotkit/runtime": "^1.61.2",
    "@curator/agents": "workspace:*",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "groq-sdk": "^0.37.0",
    "openai": "^5.23.2",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/pg": "^8.11.10",
    "concurrently": "^9.1.2"
  }
}
